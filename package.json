{
  "name": "ai-ask",
  "version": "1.0.0",
  "description": "Ask 4 AIs simultaneously - Notion AI, Gemini, ChatGPT, Claude",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "cli": "node browser.mjs",
    "dist": "electron-builder"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.orot.ai-ask",
    "productName": "AI Ask",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "index.html",
      "ai-controller.cjs",
      "browser.mjs",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
