{
  "name": "ai-ask",
  "version": "1.0.0",
  "description": "Ask 4 AIs simultaneously - Notion AI, Gemini, ChatGPT, Claude",
  "main": "src/main.cjs",
  "scripts": {
    "start": "node browser.mjs",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "ai.orot.ai-ask",
    "productName": "AI Ask",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
